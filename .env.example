# Pancake POS API credentials
PANCAKE_API_KEY=your_api_key_here
PANCAKE_SHOP_ID=your_shop_id_here

# Optional: override base URL (default: https://pos.pages.fm/api/v1)
# PANCAKE_BASE_URL=https://pos.pages.fm/api/v1

# HTTP transport port (default: 3000)
# PORT=3000

# Bearer token for HTTP transport authentication (recommended for production)
# MCP_AUTH_TOKEN=your_secret_token_here
